rules_version = '2';

// =============================================================
// FIRESTORE GÜVENLİK KURALLARI
// -------------------------------------------------------------
// Temel Paket: sadece giriş yapmış kullanıcı (sekreter/işletme
// sahibi) okuyup yazabilir. Firebase Console > Authentication'da
// e-posta/şifre ile kullanıcı açılır (KURULUM.md'ye bak).
//
// GELİŞMİŞ PAKET NOTU: Online randevu sayfası eklendiğinde
// "randevular" için kontrollü herkese-açık yazma kuralı buraya
// eklenecek. Şimdilik kapalı.
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

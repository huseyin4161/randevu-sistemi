rules_version = '2';

// =============================================================
// FIRESTORE GÜVENLİK KURALLARI
// -------------------------------------------------------------
// Temel Paket: sadece giriş yapmış kullanıcı (sekreter/işletme
// sahibi) okuyup yazabilir.
//
// "Sadece ilk hesap" kayıt kısıtlaması burada da (istemci
// tarafındaki app.js/auth.js kontrolüne ek olarak, asıl güvenlik
// katmanı olarak) uygulanır: kayıt formuyla oluşturulan hesap
// giriş yapabilir ANCAK verilere erişebilmesi için ya
// kullanicilar/{uid} altında kayıtlı olması (ilk kurulumu
// tamamlamış kullanıcı) ya da kurulumun henüz hiç
// tamamlanmamış olması (ayarlar/kurulum belgesi yok) gerekir.
// İkinci koşul, uygulamanın önceden Console'dan elle açılmış
// hesapları da (ilk girişte) yetkili listeye eklemesine izin
// verir (KURULUM.md adım 5'e bak).
// =============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null &&
        (exists(/databases/$(database)/documents/kullanicilar/$(request.auth.uid)) ||
         !exists(/databases/$(database)/documents/ayarlar/kurulum));
    }
  }
}
